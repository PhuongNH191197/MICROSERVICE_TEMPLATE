{
  "permissions": {
    "allow": [
      "Bash(rtk git *)",
      "Bash(docker-compose down *)",
      "Bash(docker-compose up *)",
      "Bash(docker-compose ps *)",
      "Bash(rtk docker *)",
      "PowerShell(curl *)",
      "PowerShell(curl.exe -s -X POST http://localhost:8765/detect -F \"file=@D:\\\\MICROSERVICE_TEMPLATE\\\\python-services\\\\data-test\\\\test_khong_loi.mp3\")",
      "PowerShell(curl.exe -s -X POST http://localhost:8765/detect -F \"file=@D:\\\\MICROSERVICE_TEMPLATE\\\\python-services\\\\data-test\\\\co_loi.mp3\")",
      "PowerShell(powershell -NonInteractive -File D:\\MICROSERVICE_TEMPLATE\\scripts\\update-tree.ps1)",
      "Bash(rtk grep *)",
      "mcp__plugin_context-mode_context-mode__ctx_batch_execute",
      "Bash(rtk ls *)",
      "Bash(rtk read *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NonInteractive -Command \"$f = $env:CLAUDE_TOOL_INPUT_FILE_PATH; if ($f -like '*Dockerfile' -or $f -like '*pom.xml' -or $f -like '*requirements.txt') { & 'D:\\MICROSERVICE_TEMPLATE\\scripts\\update-tree.ps1' }\"",
            "shell": "powershell",
            "statusMessage": "Updating PROJECT_TREE.md...",
            "async": true
          }
        ]
      }
    ]
  }
}
