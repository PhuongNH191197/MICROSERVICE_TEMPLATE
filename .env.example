# Copy to .env before running docker-compose
# Flyway — dev: false (skip checksum validation) | prod: true (strict)
FLYWAY_VALIDATE_ON_MIGRATE=false
POSTGRES_DB=platform_db
POSTGRES_USER=platform_user
POSTGRES_PASSWORD=platform_pass
REDIS_PASSWORD=redis_pass
RABBITMQ_DEFAULT_USER=rabbit_user
RABBITMQ_DEFAULT_PASS=rabbit_pass
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_PROTOCOL=http
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_pass123

# File upload limits & buckets
FILE_MAX_SIZE_MB=20
FILE_PRESIGNED_URL_EXPIRY_HOURS=1
FILE_BUCKET_AUDIO=audio
FILE_BUCKET_DEFAULT=documents
EUREKA_USERNAME=admin
EUREKA_PASSWORD=admin_pass
CONFIG_SERVER_USERNAME=config_admin
CONFIG_SERVER_PASSWORD=config_pass
JWT_SECRET=your-256-bit-secret-key-change-in-production-must-be-at-least-32-chars
JWT_ACCESS_EXPIRY_MS=900000
JWT_REFRESH_EXPIRY_MS=604800000
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@platform.com
APP_URL=http://localhost:8080

# JWT (additional keys)
JWT_REFRESH_SECRET=your-refresh-secret-key-here-change-in-production
JWT_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# Services (internal Docker network URLs)
EUREKA_SERVER_URL=http://eureka-server:8761/eureka/
CONFIG_SERVER_URL=http://config-server:8888

# Swagger / OpenAPI
# Set to false to disable Swagger UI and /v3/api-docs in all services
SWAGGER_ENABLED=true
