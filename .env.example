# Copy to .env before running docker-compose
POSTGRES_DB=platform_db
POSTGRES_USER=platform_user
POSTGRES_PASSWORD=platform_pass
REDIS_PASSWORD=redis_pass
RABBITMQ_DEFAULT_USER=rabbit_user
RABBITMQ_DEFAULT_PASS=rabbit_pass
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_pass123
EUREKA_USERNAME=admin
EUREKA_PASSWORD=admin_pass
CONFIG_SERVER_USERNAME=config_admin
CONFIG_SERVER_PASSWORD=config_pass
JWT_SECRET=your-256-bit-secret-key-change-in-production-must-be-at-least-32-chars
JWT_ACCESS_EXPIRY_MS=900000
JWT_REFRESH_EXPIRY_MS=604800000
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@platform.com
APP_URL=http://localhost:8080
